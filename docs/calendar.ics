<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Orthopaedic Abstract Deadline Calendar</title>
  <style>
    :root { font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, sans-serif; color: #172033; background:#f6f7fb; }
    body { margin:0; }
    header { padding: 40px 24px; background: linear-gradient(135deg,#16213e,#30475e); color:white; }
    main { padding: 24px; max-width: 1180px; margin:auto; }
    h1 { margin:0 0 8px; font-size: clamp(28px,4vw,46px); }
    .sub { opacity:.9; max-width:800px; line-height:1.5; }
    .bar { display:flex; gap:12px; flex-wrap:wrap; margin: 20px 0; }
    input, select, a.button { padding:10px 12px; border-radius:12px; border:1px solid #d7dce8; background:white; font-size:14px; }
    input { flex: 1 1 280px; }
    a.button { text-decoration:none; color:#172033; font-weight:700; }
    .cards { display:grid; grid-template-columns: repeat(auto-fit,minmax(290px,1fr)); gap:16px; }
    .card { background:white; border:1px solid #e4e8f2; border-radius:18px; padding:18px; box-shadow:0 8px 20px rgba(20,30,60,.06); }
    .deadline { font-size:24px; font-weight:800; margin: 6px 0; }
    .name { font-weight:800; font-size:18px; }
    .meta { color:#596276; font-size:14px; margin:6px 0; line-height:1.4; }
    .tags { display:flex; gap:6px; flex-wrap:wrap; margin-top:12px; }
    .tag { background:#eef2ff; padding:5px 8px; border-radius:999px; font-size:12px; }
    .watch { background:#fff7ed; }
    .ok { color:#0f766e; font-weight:700; }
    .warn { color:#b45309; font-weight:700; }
    footer { color:#677085; padding: 24px; text-align:center; font-size:13px; }
  </style>
</head>
<body>
<header>
  <h1>Orthopaedic Abstract Deadline Calendar</h1>
  <div class="sub">Auto-updated conference abstract tracker with specialty filters, international meetings, acceptance-strategy notes, indexed/publication notes, and a subscribable iCal feed.</div>
</header>
<main>
  <div class="bar">
    <input id="q" placeholder="Search conference, specialty, tags…" />
    <select id="specialty"><option value="">All specialties</option></select>
    <select id="region"><option value="">All regions</option><option>United States</option><option>International</option></select>
    <select id="tag"><option value="">All tags</option></select>
    <a class="button" href="ortho-abstract-deadlines.ics">Subscribe / download iCal</a>
  </div>
  <p class="meta"><span id="count"></span> · “watch” means the source is monitored, but no exact future deadline has been confidently detected yet.</p>
  <section class="cards" id="cards"></section>
</main>
<footer>Generated by GitHub Actions. Always verify high-stakes submissions on the official conference page.</footer>
<script>
const fmt = d => d ? new Date(d + 'T12:00:00').toLocaleDateString(undefined,{year:'numeric',month:'short',day:'numeric'}) : 'Watchlist';
let rows=[];
async function load(){
  rows = await fetch('conferences.json').then(r=>r.json());
  const specialties=[...new Set(rows.flatMap(r=>r.specialty||[]))].sort();
  const tags=[...new Set(rows.flatMap(r=>r.tags||[]))].sort();
  specialty.innerHTML += specialties.map(s=>`<option>${s}</option>`).join('');
  tag.innerHTML += tags.map(s=>`<option>${s}</option>`).join('');
  render();
}
function render(){
  const query=q.value.toLowerCase();
  const sp=specialty.value, rg=region.value, tg=tag.value;
  const filtered=rows.filter(r=>{
    const blob=JSON.stringify(r).toLowerCase();
    return (!query || blob.includes(query)) && (!sp || (r.specialty||[]).includes(sp)) && (!rg || r.region===rg) && (!tg || (r.tags||[]).includes(tg));
  }).sort((a,b)=>(a.deadline||a.known_deadline||'9999').localeCompare(b.deadline||b.known_deadline||'9999'));
  count.textContent = `${filtered.length} conferences shown`;
  cards.innerHTML = filtered.map(r=>`
    <article class="card ${r.status==='watch'?'watch':''}">
      <div class="name">${r.name}</div>
      <div class="deadline">${fmt(r.deadline||r.known_deadline)}</div>
      <div class="meta"><b>${r.deadline_label||''}</b></div>
      <div class="meta">${(r.specialty||[]).join(' · ')} · ${r.region||''}</div>
      <div class="meta">Meeting: ${r.meeting_date||'TBD'}</div>
      <div class="meta"><b>Acceptance:</b> ${r.acceptance_strategy||''}</div>
      <div class="meta"><b>Indexed/publication:</b> ${r.indexed||''}</div>
      <div class="meta"><b>Status:</b> <span class="${r.source_ok?'ok':'warn'}">${r.status||'watch'}${r.source_ok===false?' · source check failed':''}</span></div>
      <div class="meta"><a href="${r.source_url}" target="_blank" rel="noopener">Official source</a></div>
      <div class="tags">${(r.tags||[]).map(t=>`<span class="tag">${t}</span>`).join('')}</div>
    </article>`).join('');
}
[q,specialty,region,tag].forEach(el=>el.addEventListener('input',render));
load();
</script>
</body>
</html>
